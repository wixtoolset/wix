<element name="GetCapabilities">
    <annotation>
      <appinfo>
        <parent namespace="http://wixtoolset.org/schemas/v4/wxs" ref="Fragment" />
        <parent namespace="http://wixtoolset.org/schemas/v4/wxs" ref="Module" />
        <parent namespace="http://wixtoolset.org/schemas/v4/wxs" ref="Package" />
        <parent namespace="http://wixtoolset.org/schemas/v4/wxs" ref="UI" />
      </appinfo>
      <documentation>
        Schedules the WixToolset.DirectX.wixext custom action for the current platform to
        detect DirectX capabilities. For more information, see [DirectX custom actions](../../../tools/wixext/directx).
      </documentation>
    </annotation>
    <complexType>
      <choice minOccurs="0" maxOccurs="unbounded">
        <any namespace="##other" processContents="lax">
          <annotation>
            <documentation>
              Extensibility point in the WiX XML Schema. Schema extensions can register additional
              elements at this point in the schema.
            </documentation>
          </annotation>
        </any>
      </choice>
      <anyAttribute namespace="##other" processContents="lax">
        <annotation>
          <documentation>
            Extensibility point in the WiX XML Schema. Schema extensions can register additional
            attributes at this point in the schema.
          </documentation>
        </annotation>
      </anyAttribute>
    </complexType>
  </element>