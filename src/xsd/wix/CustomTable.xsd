<element name="CustomTable">
    <annotation>
      <documentation>Defines a custom table for use from a custom action.</documentation>
    </annotation>
    <complexType>
      <choice maxOccurs="unbounded">
        <element ref="Column">
          <annotation>
            <documentation>Column definition for the custom table.</documentation>
          </annotation>
        </element>
        <element ref="Row">
          <annotation>
            <documentation>Row definition for the custom table.</documentation>
          </annotation>
        </element>
        <any namespace="##other" processContents="lax">
          <annotation>
            <documentation>
              Extensibility point in the WiX XML Schema. Schema extensions can register additional
              elements at this point in the schema.
            </documentation>
          </annotation>
        </any>
      </choice>
      <attribute name="Id" type="xs:string" use="required">
        <annotation>
          <documentation>Identifier for the custom table. The id must be less than 31 characters.</documentation>
        </annotation>
      </attribute>
      <attribute name="Unreal" type="YesNoType">
        <annotation>
          <documentation>Indicates the table is not supposed to be included in the final output.</documentation>
        </annotation>
      </attribute>
      <anyAttribute namespace="##other" processContents="lax">
        <annotation>
          <documentation>
            Extensibility point in the WiX XML Schema. Schema extensions can register additional
            attributes at this point in the schema.
          </documentation>
        </annotation>
      </anyAttribute>
    </complexType>
  </element>