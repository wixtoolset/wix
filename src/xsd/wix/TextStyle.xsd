<element name="TextStyle">
    <annotation>
      <appinfo>
        <msiRef table="TextStyle" href="https://docs.microsoft.com/en-us/windows/win32/msi/textstyle-table" />
      </appinfo>
    </annotation>
    <complexType>
      <attribute name="Id" type="xs:string">
        <annotation>
          <documentation>
            An optional identifier for the text style in the database. If one is not specified,
            one will be generated.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="FaceName" use="required" type="xs:string">
        <annotation>
          <documentation>The face name of the font.</documentation>
        </annotation>
      </attribute>
      <attribute name="Size" use="required" type="xs:string">
        <annotation>
          <documentation>The font's size.</documentation>
        </annotation>
      </attribute>
      <attribute name="Red" type="Integer">
        <annotation>
          <documentation>A value from 0 to 255 to indicate the amount of red in the font.</documentation>
        </annotation>
      </attribute>
      <attribute name="Green" type="Integer">
        <annotation>
          <documentation>A value from 0 to 255 to indicate the amount of green in the font.</documentation>
        </annotation>
      </attribute>
      <attribute name="Blue" type="Integer">
        <annotation>
          <documentation>A value from 0 to 255 to indicate the amount of blue in the font.</documentation>
        </annotation>
      </attribute>
      <attribute name="Bold" type="YesNoTypeUnion">
        <annotation>
          <documentation>Indicates whether the font should be bold. Default is 'false'.</documentation>
        </annotation>
      </attribute>
      <attribute name="Italic" type="YesNoTypeUnion">
        <annotation>
          <documentation>Indicates whether the font should be italic. Default is 'false'.</documentation>
        </annotation>
      </attribute>
      <attribute name="Underline" type="YesNoTypeUnion">
        <annotation>
          <documentation>Indicates whether the font should be underline. Default is 'false'.</documentation>
        </annotation>
      </attribute>
      <attribute name="Strike" type="YesNoTypeUnion">
        <annotation>
          <documentation>Indicates whether the font should be strikethrough. Default is 'false'.</documentation>
        </annotation>
      </attribute>
      <anyAttribute namespace="##other" processContents="lax">
        <annotation>
          <documentation>
            Extensibility point in the WiX XML Schema. Schema extensions can register additional
            attributes at this point in the schema.
          </documentation>
        </annotation>
      </anyAttribute>
    </complexType>
  </element>