<element name="RemoteBundle">
    <annotation>
      <documentation>
        Describes information about the referenced Bundle.
      </documentation>
    </annotation>
    <complexType>
      <choice minOccurs="0" maxOccurs="unbounded">
        <element ref="RemoteRelatedBundle" />
        <any namespace="##other" processContents="lax">
          <annotation>
            <documentation>
              Extensibility point in the WiX XML Schema. Schema extensions can register additional
              elements at this point in the schema.
            </documentation>
          </annotation>
        </any>
      </choice>
      <attribute name="BundleId" type="Guid" use="required">
        <annotation>
          <documentation>
            The id of the bundle.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="DisplayName" type="xs:string">
        <annotation>
          <documentation>
            The display name of the bundle.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="EngineVersion" type="xs:string">
        <annotation>
          <documentation>
            The version of the bundle's engine.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="InstallSize" type="xs:string">
        <annotation>
          <documentation>
            The size this bundle will take on disk in bytes after it is installed.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="ManifestNamespace" type="xs:string" use="required">
        <annotation>
          <documentation>
            The namespace of the bundle's manifest.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="PerMachine" type="YesNoTypeUnion" use="required">
        <annotation>
          <documentation>
            Whether the bundle is per-machine.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="ProtocolVersion" type="Integer" use="required">
        <annotation>
          <documentation>
            The protocol version of the related bundle.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="ProviderKey" type="xs:string" use="required">
        <annotation>
          <documentation>
            The provider key of the bundle.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="UpgradeCode" type="Guid" use="required">
        <annotation>
          <documentation>
            An upgrade code of the bundle.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="Version" type="xs:string" use="required">
        <annotation>
          <documentation>
            The version of the bundle.
          </documentation>
        </annotation>
      </attribute>
      <attribute name="Win64" type="YesNoTypeUnion" use="required">
        <annotation>
          <documentation>
            Whether the bundle is 64-bit.
          </documentation>
        </annotation>
      </attribute>
      <anyAttribute namespace="##other" processContents="lax">
        <annotation>
          <documentation>
            Extensibility point in the WiX XML Schema. Schema extensions can register additional
            attributes at this point in the schema.
          </documentation>
        </annotation>
      </anyAttribute>
    </complexType>
  </element>