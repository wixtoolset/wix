<element name="MsuPackagePayload">
    <annotation>
      <documentation>
        Describes information about the MsuPackage payload.
        Cannot be specified if the owning MsuPackage specified any of SourceFile, Name, DownloadUrl, or Compressed.
      </documentation>
    </annotation>
    <complexType>
      <attributeGroup ref="ChainPackagePayloadCommonAttributes" />
      <attributeGroup ref="RemotePackagePayloadCommonAttributes" />
    </complexType>
  </element>