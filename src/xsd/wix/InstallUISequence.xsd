      </appinfo>
    </annotation>
    <complexType>
      <choice minOccurs="0" maxOccurs="unbounded">
        <element ref="Custom" minOccurs="0" maxOccurs="unbounded">
          <annotation>
            <documentation>Use to sequence a custom action.</documentation>
          </annotation>
        </element>
        <element ref="Show" minOccurs="0" maxOccurs="unbounded">
          <annotation>
            <documentation>Displays a Dialog.</documentation>
          </annotation>
        </element>
        <element ref="ScheduleReboot" minOccurs="0">
