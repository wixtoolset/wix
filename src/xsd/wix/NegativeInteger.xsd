<simpleType name="NegativeInteger">
    <annotation>
      <documentation>Values of this allow negative integer or a preprocessor variable with the format `$(Variable)` or `$(var.Variable).</documentation>
    </annotation>
    <restriction base="xs:string">
      <pattern value="-?[\d]+|\$\((var\.)?[_A-Za-z]{1}[0-9A-Za-z_\.]*\)" />
    </restriction>
  </simpleType>