<simpleType name="VersionType">
    <annotation>
      <documentation>Values of this type will look like: "x.x.x.x" where x is an integer from 0 to 65534.</documentation>
    </annotation>
    <restriction base="xs:string">
      <pattern value="(\d{1,5}\.){3}\d{1,5}" />
    </restriction>
  </simpleType>