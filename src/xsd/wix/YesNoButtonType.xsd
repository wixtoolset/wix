<simpleType name="YesNoButtonType">
    <annotation>
      <documentation>Values of this type will either be "button", "yes"/"true", or "no"/"false".</documentation>
    </annotation>
    <restriction base="xs:NMTOKEN">
      <enumeration value="no" />
      <enumeration value="false" />
      <enumeration value="yes" />
      <enumeration value="true" />
      <enumeration value="button" />
    </restriction>
  </simpleType>